# Senha única de acesso ao painel — usada APENAS no backend (Vercel Functions).
APP_PASSWORD=senha_de_acesso_aqui

# Segredo para assinar os tokens de sessão (JWT). Use um valor longo e aleatório.
JWT_SECRET=troque_por_uma_string_longa_e_aleatoria

# Segredo compartilhado do SSO com o Portal DAL. Deve ser IGUAL em todos os
# projetos DAL (portal, manual e painéis) para o acesso único funcionar.
SSO_SECRET=um_segredo_longo_e_aleatorio

# Observação: este painel NÃO acessa a API do Contratos.gov.br. Os dados são
# importados manualmente pelo gestor (planilha .xlsx/.csv exportada do sistema)
# e processados no próprio navegador — nenhum dado de contrato trafega pelo
# servidor. Por isso não há credenciais do Comprasnet aqui.
